<%-include('../layouts/user/OtpHeader')-%>




  <div class="container">
    <header>
      <i class="bx bxs-check-shield"></i>
    </header>
    <h4>Enter OTP Code</h4>
    <p>Your code was sent to you via email</p>
    
    <form action="" method="post">
      <div class="input-field" id="otp">
        <input type="number" name="a" oninput="moveToNextInput(this)" maxlength="1" />
        <input type="number" name="b" disabled maxlength="1"/>
        <input type="number" name="c" disabled maxlength="1"/>
        <input type="number" name="d" disabled maxlength="1"/>
        <input type="number" name="e" disabled maxlength="1"/>
        <input type="number" name="f" disabled maxlength="1"/>
      </div>
      <% if(typeof message !=='undefined' ){ %>

        <h6 class="text-danger">
          <%= message %>
        </h6>

        <% } %>
         
  <div class="button-container">
    <button type="button" onclick="cancelForm()">Cancel</button>
    <button type="submit">Verify OTP</button>

  </div>

  <a href="#">Resend OTP</a>
    </form>
  </div>
  <script>

    // Adding one input at a time
    function moveToNextInput(currentInput) {
        // Get the next input element
        var nextInput = currentInput.nextElementSibling;

        // Check if there is a next input element
        if (nextInput) {
            // Enable the next input
            nextInput.disabled = false;

            // Focus on the next input
            nextInput.focus();
        }
    }
</script>

  <script src="js/userOtp.js"></script>

  <%-include('../layouts/user/OtpFooter')-%>
    <%-include('../layouts/user/footer')-%>